# App
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:5173

# Database (coincide con kanban-infra/.env.example)
DATABASE_URL=postgresql://kanban:kanban@localhost:5432/kanban?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=change-me-access
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12

# Storage (MinIO local; vaciar STORAGE_ENDPOINT para AWS S3)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=kanban-attachments
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_URL=http://localhost:9000/kanban-attachments

# Uploads
UPLOAD_MAX_BYTES=10485760
UPLOAD_ALLOWED_MIME=image/png,image/jpeg,image/webp,image/gif,application/pdf,text/plain
