// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  moduleFormat  = "cjs"
}

datasource db {
  provider = "postgresql"
}



enum BoardRole {
  owner
  admin
  member
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique @db.VarChar(255)
  name          String   @db.VarChar(100)
  passwordHash  String   @map("password_hash") @db.VarChar(255)
  avatarUrl     String?  @map("avatar_url") @db.VarChar(500)
  roles         String[] @default([])
  profile       Json     @default("{}")
  preferences   Json     @default("{}")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz
  lastLoginAt   DateTime? @map("last_login_at") @db.Timestamptz

  ownedBoards   Board[]         @relation("BoardOwner")
  memberships   BoardMember[]
  cardMembers   CardMember[]
  comments      Comment[]
  activities    Activity[]
  refreshTokens RefreshToken[]

  @@index([email])
  @@map("users")
}

model Board {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(200)
  background  String   @default("bg-gradient-to-br from-blue-500 to-purple-600") @db.VarChar(200)
  ownerId     String   @map("owner_id") @db.Uuid
  preferences Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  owner       User           @relation("BoardOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     BoardMember[]
  stages      Stage[]
  labels      Label[]
  activities  Activity[]
  invitations Invitation[]

  @@index([ownerId])
  @@map("boards")
}

model BoardMember {
  id          String    @id @default(uuid()) @db.Uuid
  boardId     String    @map("board_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  role        BoardRole @default(member)
  permissions String[]  @default([])
  invitedAt   DateTime  @default(now()) @map("invited_at") @db.Timestamptz

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([boardId])
  @@index([userId])
  @@map("board_members")
}

model Stage {
  id        String   @id @default(uuid()) @db.Uuid
  boardId   String   @map("board_id") @db.Uuid
  name      String   @db.VarChar(200)
  position  Float    @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([boardId, position])
  @@map("stages")
}

model Label {
  id      String @id @default(uuid()) @db.Uuid
  boardId String @map("board_id") @db.Uuid
  name    String @db.VarChar(50)
  color   String @db.VarChar(20)

  board      Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cardLabels CardLabel[]

  @@map("labels")
}

model Card {
  id          String    @id @default(uuid()) @db.Uuid
  stageId     String    @map("stage_id") @db.Uuid
  title       String    @db.VarChar(500)
  description String    @default("") @db.Text
  position    Float     @default(0)
  startDate   DateTime? @map("start_date") @db.Date
  dueDate     DateTime? @map("due_date") @db.Date
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  stage           Stage           @relation(fields: [stageId], references: [id], onDelete: Cascade)
  labels          CardLabel[]
  members         CardMember[]
  checklistItems  ChecklistItem[]
  comments        Comment[]

  @@index([stageId, position])
  @@index([dueDate])
  @@map("cards")
}

model ChecklistItem {
  id       String  @id @default(uuid()) @db.Uuid
  cardId   String  @map("card_id") @db.Uuid
  text     String  @db.VarChar(500)
  done     Boolean @default(false)
  position Float   @default(0)

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, position])
  @@map("checklist_items")
}

model CardLabel {
  cardId  String @map("card_id") @db.Uuid
  labelId String @map("label_id") @db.Uuid

  card  Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
  @@map("card_labels")
}

model CardMember {
  cardId   String   @map("card_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamptz

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([cardId, userId])
  @@map("card_members")
}

model Comment {
  id        String   @id @default(uuid()) @db.Uuid
  cardId    String   @map("card_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  card   Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([cardId, createdAt])
  @@map("comments")
}

model Activity {
  id        String   @id @default(uuid()) @db.Uuid
  boardId   String   @map("board_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(100)
  detail    String   @db.Text
  meta      Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([boardId, createdAt(sort: Desc)])
  @@map("activities")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Invitation {
  id         String    @id @default(uuid()) @db.Uuid
  boardId    String    @map("board_id") @db.Uuid
  email      String    @db.VarChar(255)
  role       BoardRole @default(member)
  token      String    @unique @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  acceptedAt DateTime? @map("accepted_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId])
  @@index([email])
  @@map("invitations")
}
