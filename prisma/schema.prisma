// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  moduleFormat  = "cjs"
}

datasource db {
  provider = "postgresql"
}



enum BoardRole {
  owner
  admin
  member
}



model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique @db.VarChar(255)
  name          String   @db.VarChar(100)
  username      String?  @unique @map("username") @db.VarChar(50)
  passwordHash  String   @map("password_hash") @db.VarChar(255)
  avatarUrl     String?  @map("avatar_url") @db.VarChar(500)
  roles         String[] @default([])
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz
  lastLoginAt   DateTime? @map("last_login_at") @db.Timestamptz

  profile       Profile?          @relation("UserProfile")
  preferences   UserPreference?   @relation("UserPreference")

  memberships   BoardMembership[]
  refreshTokens RefreshToken[]

  @@index([email])
  @@map("users")
}

model Profile {
  id              String   @id @default(uuid()) @db.Uuid
  displayName     String   @default("") @map("display_name") @db.VarChar(100)
  coverUrl        String?  @map("cover_url") @db.VarChar(500)
  bio             String?  @db.Text
  jobTitle        String?  @map("job_title") @db.VarChar(100)
  company         String?  @db.VarChar(100)
  location        String?  @db.VarChar(100)
  socialWebsite   String?  @map("social_website") @db.VarChar(500)
  socialTwitter   String?  @map("social_twitter") @db.VarChar(100)
  socialGithub    String?  @map("social_github") @db.VarChar(100)
  socialLinkedin  String?  @map("social_linkedin") @db.VarChar(100)
  socialInstagram String?  @map("social_instagram") @db.VarChar(100)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user   User     @relation("UserProfile", fields: [userId], references: [id], onDelete: Cascade)
  userId String   @unique @map("user_id") @db.Uuid

  @@map("profiles")
}

model UserPreference {
  id        String   @id @default(uuid()) @db.Uuid

  theme           String   @default("light") @db.VarChar(20)
  background      String   @default("plain") @db.VarChar(50)
  density         String   @default("comfortable") @db.VarChar(20)
  language        String   @default("es") @db.VarChar(10)
  timezone        String   @default("") @db.VarChar(50)
  timeFormat      String   @default("24h") @db.VarChar(5)
  dateFormat      String   @default("DMY") @db.VarChar(5)
  reducedMotion   Boolean  @default(false) @map("reduced_motion")
  showCompletedCards Boolean @default(true) @map("show_completed_cards")

  emailEnabled    Boolean  @default(true) @map("email_enabled")
  pushEnabled     Boolean  @default(false) @map("push_enabled")
  mentions        Boolean  @default(true)
  cardAssigned    Boolean  @default(true) @map("card_assigned")
  cardDueSoon     Boolean  @default(true) @map("card_due_soon")
  boardInvites    Boolean  @default(true) @map("board_invites")
  weeklyDigest    Boolean  @default(false) @map("weekly_digest")

  profileVisibility String @default("workspace") @map("profile_visibility") @db.VarChar(20)
  showEmail        Boolean  @default(false) @map("show_email")
  showActivity     Boolean  @default(true) @map("show_activity")
  allowDM          Boolean  @default(true) @map("allow_dm")
  analyticsOptOut  Boolean  @default(false) @map("analytics_opt_out")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user     User     @relation("UserPreference", fields: [userId], references: [id], onDelete: Cascade)
  userId   String   @unique @map("user_id") @db.Uuid

  @@map("user_preferences")
}

model Board {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(200)
  background  String   @default("bg-gradient-to-br from-blue-500 to-purple-600") @db.VarChar(200)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  members     BoardMembership[]
  stages      Stage[]
  labels      Label[]
  activities  Activity[]
  invitations Invitation[]

  preference  BoardPreference? @relation("BoardPreference")

  @@map("boards")
}

model BoardPreference {
  id        String   @id @default(uuid()) @db.Uuid
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  board    Board    @relation("BoardPreference", fields: [boardId], references: [id], onDelete: Cascade)
  boardId  String   @unique @map("board_id") @db.Uuid

  @@index([boardId])
  @@map("board_preferences")
}

model BoardMembership {
  id          String    @id @default(uuid()) @db.Uuid
  boardId     String    @map("board_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  role        BoardRole @default(member)
  permissions String[]  @default([])
  invitedAt   DateTime  @default(now()) @map("invited_at") @db.Timestamptz

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardMembers CardMember[]
  comments    Comment[]
  activities  Activity[]

  @@unique([boardId, userId])
  @@index([boardId])
  @@index([userId])
  @@map("board_members")
}

model Stage {
  id        String   @id @default(uuid()) @db.Uuid
  boardId   String   @map("board_id") @db.Uuid
  name      String   @db.VarChar(200)
  position  Float    @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([boardId, position])
  @@map("stages")
}

model Label {
  id      String @id @default(uuid()) @db.Uuid
  boardId String @map("board_id") @db.Uuid
  name    String @db.VarChar(50)
  color   String @db.VarChar(20)

  board      Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cardLabels CardLabel[]

  @@map("labels")
}

model Card {
  id          String    @id @default(uuid()) @db.Uuid
  stageId     String    @map("stage_id") @db.Uuid
  title       String    @db.VarChar(500)
  description String    @default("") @db.Text
  position    Float     @default(0)
  startDate   DateTime? @map("start_date") @db.Date
  dueDate     DateTime? @map("due_date") @db.Date
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  stage           Stage           @relation(fields: [stageId], references: [id], onDelete: Cascade)
  labels          CardLabel[]
  members         CardMember[]
  checklistItems  ChecklistItem[]
  comments        Comment[]

  @@index([stageId, position])
  @@index([dueDate])
  @@map("cards")
}

model ChecklistItem {
  id       String  @id @default(uuid()) @db.Uuid
  cardId   String  @map("card_id") @db.Uuid
  text     String  @db.VarChar(500)
  done     Boolean @default(false)
  position Float   @default(0)

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, position])
  @@map("checklist_items")
}

model CardLabel {
  cardId  String @map("card_id") @db.Uuid
  labelId String @map("label_id") @db.Uuid

  card  Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
  @@map("card_labels")
}

model CardMember {
  cardId            String        @map("card_id") @db.Uuid
  boardMembershipId String        @map("board_membership_id") @db.Uuid
  joinedAt          DateTime      @default(now()) @map("joined_at") @db.Timestamptz

  card            Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  boardMembership BoardMembership @relation(fields: [boardMembershipId], references: [id], onDelete: Cascade)

  @@id([cardId, boardMembershipId])
  @@index([boardMembershipId])
  @@map("card_members")
}

model Comment {
  id        String   @id @default(uuid()) @db.Uuid
  cardId    String   @map("card_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  author BoardMembership @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([cardId, createdAt])
  @@index([authorId])
  @@map("comments")
}

model Activity {
  id        String   @id @default(uuid()) @db.Uuid
  boardId   String   @map("board_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(100)
  detail    String   @db.Text
  meta      Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  BoardMembership @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([boardId, createdAt(sort: Desc)])
  @@index([userId])
  @@map("activities")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Invitation {
  id         String    @id @default(uuid()) @db.Uuid
  boardId    String    @map("board_id") @db.Uuid
  email      String    @db.VarChar(255)
  role       BoardRole @default(member)
  token      String    @unique @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  acceptedAt DateTime? @map("accepted_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId])
  @@index([email])
  @@map("invitations")
}
